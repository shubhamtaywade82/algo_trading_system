#!/usr/bin/env ruby
# frozen_string_literal: true

require 'optparse'
require 'time'
require 'dotenv/load'
require_relative '../src/backtest/orchestrator'

options = {
  underlying: 'nifty',
  strategy: :rsi_macd,
  from_date: (Date.today - 30).to_s,
  to_date: Date.today.to_s,
  option_type: 'CALL',
  strikes: ['ATM', 'ATM+1', 'ATM-1'],
  interval: '1',
  capital: 1_000_000
}

OptionParser.new do |opts|
  opts.banner = "Usage: backtest [options]"
  opts.on("-u", "--underlying SYM", "Underlying index (nifty, banknifty, sensex)") { |v| options[:underlying] = v }
  opts.on("-s", "--strategy NAME", "Strategy name (rsi_macd, bollinger_breakout, etc.)") { |v| options[:strategy] = v.to_sym }
  opts.on("-f", "--from DATE", "Start date (YYYY-MM-DD)") { |v| options[:from_date] = v }
  opts.on("-t", "--to DATE", "End date (YYYY-MM-DD)") { |v| options[:to_date] = v }
  opts.on("-c", "--capital AMOUNT", Float, "Starting capital") { |v| options[:capital] = v }
end.parse!

orchestrator = Backtest::Orchestrator.new(
  access_token: ENV['DHAN_ACCESS_TOKEN'],
  capital: options[:capital]
)

begin
  orchestrator.run_backtest(config: options)
rescue StandardError => e
  puts "Error: #{e.message}"
  exit 1
end
