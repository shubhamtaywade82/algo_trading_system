#!/usr/bin/env ruby
# frozen_string_literal: true

require 'optparse'
require_relative '../src/live_runner'
require_relative '../src/strategies/trading_strategies'

options = {
  strategy: 'ema_crossover',
  symbol: 'NIFTY',
  env: ENV.fetch('TRADING_ENV', 'paper'),
  interval: 1
}

OptionParser.new do |opts|
  opts.banner = "Usage: trade [options]"

  opts.on("-s", "--strategy NAME", "Strategy to run (default: #{options[:strategy]})") { |v| options[:strategy] = v }
  opts.on("-y", "--symbol SYM", "Trading symbol (NIFTY, BANKNIFTY, FINNIFTY, SENSEX) (default: #{options[:symbol]})") { |v| options[:symbol] = v }
  opts.on("-e", "--env ENV", "Trading environment (paper, live) (default: #{options[:env]})") { |v| options[:env] = v }
  opts.on("-i", "--interval MIN", Integer, "Candle interval in minutes (default: #{options[:interval]})") { |v| options[:interval] = v }
  
  opts.on("-l", "--list-strategies", "List available strategies") do
    puts "Available strategies:"
    TradingStrategies::StrategyFactory.available_strategies.each { |s| puts "  - #{s}" }
    exit
  end

  opts.on("-h", "--help", "Prints this help") do
    puts opts
    exit
  end
end.parse!

runner = AlgoTradingSystem::LiveRunner.new(
  strategy_name: options[:strategy],
  symbol: options[:symbol],
  env: options[:env],
  interval: options[:interval]
)

Signal.trap("INT") { runner.stop; exit }

runner.start
